---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import Steps from '~/components/widgets/Steps.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Headline from '~/components/ui/Headline.astro';
import Button from '~/components/ui/Button.astro';
import Image from '~/components/common/Image.astro';
import { Icon } from 'astro-icon/components';

import { client } from '~/client';

const metadata = {
  title: client.seo.title,
  description: client.seo.description,
  ignoreTitleTemplate: true,
};

const huf = (n: number) => `${n.toLocaleString('hu-HU')} Ft`;

const toActions = (actions: typeof client.hero.actions) =>
  actions.map((a) => ({ variant: a.variant, text: a.label, href: a.href, icon: a.icon, target: a.target }));
---

<Layout metadata={metadata}>
  <!-- Hero ************************** -->

  <Hero
    tagline={client.hero.tagline}
    actions={toActions(client.hero.actions)}
    image={{ src: client.hero.image, alt: client.hero.imageAlt }}
  >
    <Fragment slot="title" set:html={client.hero.title} />
    <Fragment slot="subtitle">{client.hero.subtitle}</Fragment>
  </Hero>

  <!-- Trust strip ******************* -->

  <Stats stats={client.stats.map((s) => ({ amount: s.amount, title: s.label }))} />

  <!-- Why us ************************ -->

  <Features
    tagline={client.why.tagline}
    title={client.why.title}
    subtitle={client.why.subtitle}
    items={client.why.items}
  />

  <!-- Menu ************************** -->

  <WidgetWrapper id="etlap" containerClass="max-w-6xl mx-auto">
    <Headline tagline={client.menu.tagline} title={client.menu.title} subtitle={client.menu.subtitle} />

    <div class="flex flex-col gap-10">
      {
        client.menu.categories.map((category, idx) => (
          <div
            id={category.id}
            class="overflow-hidden rounded-3xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-900 shadow-sm"
          >
            <div class:list={['md:flex', { 'md:flex-row-reverse': idx % 2 === 1 }]}>
              {category.image && (
                <div class="relative md:w-2/5 lg:w-1/3">
                  <Image
                    src={category.image}
                    alt={category.title}
                    width={640}
                    height={520}
                    widths={[400, 640]}
                    layout="cover"
                    class="h-56 w-full object-cover md:h-full"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent md:bg-gradient-to-r" />
                  {category.tagline && (
                    <span class="absolute left-4 top-4 rounded-full bg-[#E8A33D] px-3 py-1 text-xs font-bold uppercase tracking-wide text-[#2B2118]">
                      {category.tagline}
                    </span>
                  )}
                </div>
              )}

              <div class="flex-1 p-6 md:p-8">
                <div class="mb-5 flex items-center gap-3">
                  {category.icon && <Icon name={category.icon} class="h-8 w-8 text-primary" />}
                  <div>
                    <h3 class="text-2xl font-bold tracking-tight font-heading dark:text-white">{category.title}</h3>
                    {category.description && <p class="text-sm text-muted">{category.description}</p>}
                  </div>
                </div>

                <ul class="divide-y divide-gray-100 dark:divide-slate-800">
                  {category.items.map((item) => (
                    <li class="flex items-start justify-between gap-4 py-3">
                      <div>
                        <div class="flex items-center gap-2">
                          <span class="font-semibold dark:text-white">{item.name}</span>
                          {item.popular && (
                            <span class="rounded-full bg-[#E8A33D]/20 px-2 py-0.5 text-[0.65rem] font-bold uppercase tracking-wide text-[#A6381A] dark:text-[#E8A33D]">
                              Népszerű
                            </span>
                          )}
                        </div>
                        {item.description && <p class="mt-0.5 text-sm text-muted">{item.description}</p>}
                      </div>
                      <span class="shrink-0 whitespace-nowrap font-bold text-primary">{huf(item.price)}</span>
                    </li>
                  ))}
                </ul>

                {category.extras && category.extras.length > 0 && (
                  <div class="mt-5 rounded-xl bg-[#FBF1E6] dark:bg-slate-800/60 p-4">
                    <p class="mb-2 text-xs font-bold uppercase tracking-widest text-[#A6381A] dark:text-[#E8A33D]">
                      {category.extrasTitle ?? 'Extrák'}
                    </p>
                    <div class="flex flex-wrap gap-2">
                      {category.extras.map((extra) => (
                        <span class="inline-flex items-center gap-1 rounded-full border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-900 px-3 py-1 text-sm">
                          <span class="dark:text-slate-200">{extra.name}</span>
                          <span class="font-semibold text-primary">+{huf(extra.price)}</span>
                        </span>
                      ))}
                    </div>
                  </div>
                )}
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <div class="mt-8 flex flex-col items-center gap-3 text-center">
      <p class="text-sm text-muted">{client.menu.packagingNote} &nbsp;·&nbsp; {client.menu.note}</p>
      <Button
        variant="primary"
        text="Útvonal térképen"
        href={client.contact.mapHref}
        target="_blank"
        icon="tabler:map-pin"
      />
    </div>
  </WidgetWrapper>

  <!-- About ************************* -->

  <Content
    id="rolunk"
    isReversed
    tagline={client.about.tagline}
    title={client.about.title}
    items={client.about.highlights.map((h) => ({ title: h }))}
    image={{ src: client.about.image, alt: client.about.imageAlt }}
  >
    <Fragment slot="content">
      {client.about.paragraphs.map((p) => <p class="mb-4">{p}</p>)}
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-[#FBF1E6] dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- How to visit ****************** -->

  <Steps
    id="hogyan"
    tagline={client.visit.tagline}
    title={client.visit.title}
    subtitle={client.visit.subtitle}
    items={client.visit.steps}
    image={{ src: client.visit.image, alt: client.visit.imageAlt }}
  />

  <WidgetWrapper containerClass="max-w-5xl mx-auto pt-0">
    <div
      class="flex flex-col items-center gap-4 rounded-2xl bg-[#2B2118] p-6 text-center text-amber-50 sm:flex-row sm:justify-between sm:text-left"
    >
      <div class="flex items-start gap-3">
        <Icon name="tabler:info-circle" class="mt-0.5 h-6 w-6 text-[#E8A33D]" />
        <p class="text-sm sm:text-base">{client.visit.note}</p>
      </div>
      <Button
        variant="primary"
        text="Útvonal térképen"
        href={client.contact.mapHref}
        target="_blank"
        icon="tabler:map-pin"
      />
    </div>
  </WidgetWrapper>

  <!-- FAQs ************************** -->

  <FAQs
    id="faqs"
    tagline={client.faqs.tagline}
    title={client.faqs.title}
    items={client.faqs.items.map((f) => ({ title: f.question, description: f.answer }))}
  />

  <!-- Contact ********************** -->

  <WidgetWrapper id="kapcsolat" containerClass="max-w-6xl mx-auto">
    <Headline tagline={client.contact.tagline} title={client.contact.title} subtitle={client.contact.subtitle} />

    <div class="grid gap-8 md:grid-cols-2">
      <div class="rounded-2xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-900 p-6 shadow-sm">
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <Icon name="tabler:map-pin" class="mt-0.5 h-6 w-6 text-primary" />
            <div>
              <p class="font-semibold dark:text-white">{client.contact.address}</p>
              <p class="text-sm text-muted">{client.contact.district}</p>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <Icon name="tabler:phone" class="mt-0.5 h-6 w-6 text-primary" />
            <a href={`tel:${client.contact.phone.replace(/\s/g, '')}`} class="hover:text-primary dark:text-white">
              {client.contact.phone}
            </a>
          </li>
          <li class="flex items-start gap-3">
            <Icon name="tabler:mail" class="mt-0.5 h-6 w-6 text-primary" />
            <a href={`mailto:${client.contact.email}`} class="hover:text-primary dark:text-white">
              {client.contact.email}
            </a>
          </li>
        </ul>

        <h3 class="mt-8 mb-3 text-lg font-semibold dark:text-white">Nyitvatartás</h3>
        <ul class="divide-y divide-gray-100 dark:divide-slate-700">
          {
            client.contact.openingHours.map((d) => (
              <li class="flex items-center justify-between py-2 text-sm">
                <span class="dark:text-slate-300">{d.day}</span>
                <span class:list={['font-medium', d.closed ? 'text-muted' : 'text-primary']}>{d.hours}</span>
              </li>
            ))
          }
        </ul>

        <div class="mt-6 flex flex-col gap-3 sm:flex-row">
          <Button
            variant="primary"
            text="Hívj minket"
            href={`tel:${client.contact.phone.replace(/\s/g, '')}`}
            icon="tabler:phone"
          />
          <Button
            variant="secondary"
            text="Útvonal térképen"
            href={client.contact.mapHref}
            target="_blank"
            icon="tabler:map-pin"
          />
        </div>
      </div>

      <div class="overflow-hidden rounded-2xl border border-gray-200 dark:border-slate-700 shadow-sm min-h-[320px]">
        <iframe
          title="LÁNGOSozzMA térkép"
          class="h-full w-full"
          style="border:0; min-height:320px;"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          src="https://www.google.com/maps?q=Újszász+utca+87,+1165+Budapest&output=embed"></iframe>
      </div>
    </div>
  </WidgetWrapper>

  <!-- Call to action *************** -->

  <CallToAction title={client.cta.title} subtitle={client.cta.subtitle} actions={toActions(client.cta.actions)} />
</Layout>
