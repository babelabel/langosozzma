---
import '@fontsource-variable/inter';

// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    /* Brand palette — Paprika / Fried Gold / Roasted Brown */
    --aw-color-primary: rgb(200 69 29); /* #C8451D Paprika */
    --aw-color-secondary: rgb(166 56 26); /* #A6381A Deep paprika */
    --aw-color-accent: rgb(232 163 61); /* #E8A33D Fried Gold */

    --aw-color-text-heading: rgb(43 33 24); /* #2B2118 Roasted Brown */
    --aw-color-text-default: rgb(43 33 24);
    --aw-color-text-muted: rgb(43 33 24 / 66%);
    --aw-color-bg-page: rgb(255 252 248); /* warm white */

    --aw-color-bg-page-dark: rgb(26 19 13); /* warm near-black */

    ::selection {
      background-color: rgb(246 226 196);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(233 122 80); /* lighter paprika for dark bg */
    --aw-color-secondary: rgb(200 69 29);
    --aw-color-accent: rgb(240 184 106); /* lighter fried gold */

    --aw-color-text-heading: rgb(250 246 241);
    --aw-color-text-default: rgb(237 228 218);
    --aw-color-text-muted: rgb(237 228 218 / 66%);
    --aw-color-bg-page: rgb(26 19 13);

    ::selection {
      background-color: black;
      color: snow;
    }
  }
</style>
